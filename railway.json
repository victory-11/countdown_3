{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "bun install && bun run db:generate && bun run build"
  },
  "deploy": {
    "startCommand": "bun run start",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 3
  }
}
